{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "node --max-old-space-size=384 --expose-gc dist/main",
    "healthcheckPath": "/api",
    "restartPolicyType": "ON_FAILURE"
  }
}
